{
  "name": "@bravo/context-maps",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pi context map creation and selective materialization tools.",
  "keywords": ["pi-package"],
  "scripts": {
    "check": "npm run build --workspace @bravo/source-search && tsc -p tsconfig.json --noEmit",
    "build": "npm run build --workspace @bravo/source-search && tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "dependencies": {
    "@bravo/source-search": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "engines": { "node": ">=22.13" },
  "pi": {
    "extensions": ["./extensions/pi"]
  }
}
