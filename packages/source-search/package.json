{
  "name": "@bravo/source-search",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pi extension for live ranked lexical source search.",
  "keywords": ["pi-package"],
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "exports": {
    ".": "./dist/src/api.js"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "engines": { "node": ">=22.13" },
  "pi": {
    "extensions": ["./extensions/pi"],
    "skills": []
  }
}
