{
  "name": "@bravo/codex-auth-balancer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Owned-state Codex auth balancer library and CLI.",
  "keywords": ["pi-package"],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
