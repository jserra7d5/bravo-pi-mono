{
  "name": "@bravo/tango",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Native tmux agent orchestration CLI with pi and other CLI harnesses.",
  "keywords": [
    "pi-package"
  ],
  "bin": {
    "tango": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:dashboard",
    "build:dashboard": "cd dashboard && npx vite build",
    "check": "tsc -p tsconfig.json --noEmit && npm run check:dashboard",
    "check:dashboard": "cd dashboard && npx tsc --noEmit",
    "test": "npm run build && node --test dist/*.test.js"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "react": "^18",
    "react-dom": "^18",
    "typescript": "latest",
    "vite": "^5"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/pi"
    ],
    "skills": [
      "./skills"
    ]
  }
}
