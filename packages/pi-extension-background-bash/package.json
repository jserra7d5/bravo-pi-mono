{
  "name": "@bravo/pi-extension-background-bash",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Opt-in Pi bash override with managed background tasks.",
  "keywords": ["pi-package"],
  "bin": {
    "pi-background-bash": "./dist/src/migration/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": ["./src/index.ts"]
  }
}
